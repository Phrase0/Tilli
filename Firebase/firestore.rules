rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isUser(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if isUser(userId);
    }

    match /users/{userId}/sessions/{docId} {
      allow read, write: if isUser(userId);
    }

    match /users/{userId}/categories/{docId} {
      allow read, write: if isUser(userId);
    }

    match /users/{userId}/products/{docId} {
      allow read, write: if isUser(userId);
    }

    match /users/{userId}/inventoryChanges/{docId} {
      allow read, write: if isUser(userId);
    }

    match /users/{userId}/transactions/{docId} {
      allow read, write: if isUser(userId);
    }

    match /users/{userId}/qrCodes/{docId} {
      allow read, write: if isUser(userId);
    }

    // private 子集合只開放 syncState
    // appleToken 無 rule = 客戶端自動拒絕，只有 Admin SDK 可存取
    match /users/{userId}/private/syncState {
      allow read, write: if isUser(userId);
    }
  }
}

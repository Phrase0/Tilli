rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 所有用戶資料：只能讀寫自己的
    // 涵蓋：profile.jpg、qrcode.png、products/{id}.jpg
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

  }
}
